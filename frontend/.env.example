# ──────────────────────────────────────
# Frontend — Estudio Glow
# ──────────────────────────────────────
# Copiar a .env y completar valores:
#   cp .env.example .env

# URL base de la API del backend
VITE_API_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000

# Google OAuth (mismo Client ID que backend)
VITE_GOOGLE_CLIENT_ID=

# Secreto para firmar cookies de sesión SSR
SESSION_SECRET=super-secret

# WhatsApp contact button (optional — button hidden when unset)
# Teléfono en formato internacional SIN el signo +
VITE_WHATSAPP_PHONE=
# Mensaje predefinido que se envía al abrir WhatsApp (opcional)
VITE_WHATSAPP_MESSAGE=
