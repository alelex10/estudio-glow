{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "generate": "drizzle-kit generate",
    "migrate": "bun run src/migrate.ts",
    "seed": "bun run src/seeds/index.ts",
    "seed:users": "bun run src/seeds/seed-users.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "backup": "bash scripts/backup.sh",
    "backup:plain": "bash scripts/backup.sh plain",
    "restore": "bash scripts/restore.sh",
    "openapi:dump": "bun run scripts/dump-openapi.ts",
    "openapi:check": "bash scripts/check-openapi-sync.sh"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.3",
    "@types/jsonwebtoken": "^9.0.5",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "mercadopago": "^2.12.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "openapi3-ts": "^4.5.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.8",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.13"
  }
}
