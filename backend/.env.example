# ──────────────────────────────────────
# Backend — Estudio Glow
# ──────────────────────────────────────
# Copiar a .env y completar valores:
#   cp .env.example .env

# Entorno: development | production | test
NODE_ENV=development

# PostgreSQL (ej: Supabase pooler host)
DATABASE_URL=postgres://user:pass@localhost:5432/estudio_glow

# JWT — mínimo 16 caracteres, generar con: openssl rand -base64 32
JWT_SECRET=replace-with-openssl-rand-base64-32-min

# Google OAuth
GOOGLE_CLIENT_ID=

# Cloudinary (imágenes de productos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# MercadoPago
MP_ACCESS_TOKEN=APP_USR-...
WEBHOOK_URL=https://your-domain.com/api/webhooks/mercadopago

# Frontend URLs (para CORS y redirects)
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_PREVIEW=https://*.vercel.app

# Backend URL (para emails que apuntan al backend, ej: /auth/verify-email)
BACKEND_URL=http://localhost:3000

# Password por defecto para seeds (solo development)
SEED_DEFAULT_PASSWORD=change-me-in-dev

# Email provider (elegí uno) || o resend
EMAIL_PROVIDER=gmail
EMAIL_FROM=Estudio Glow <noreply@yourdomain.com>

# Si EMAIL_PROVIDER=gmail
GMAIL_USER=generar@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Si EMAIL_PROVIDER=resend (cuando destrabes el DNS del cliente)
RESEND_API_KEY=re_xxx...